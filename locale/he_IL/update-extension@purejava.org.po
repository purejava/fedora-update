#: prefs.xml:153
msgid "Position in Panel"
msgstr "מיקום בפאנל"

#: prefs.xml:171
msgid "Left"
msgstr "שמאל"

#: prefs.xml:172
msgid "Center"
msgstr "אמצע"

#: prefs.xml:173
msgid "Right"
msgstr "ימין"

#: prefs.xml:192
msgid "Menu"
msgstr "תפריט"

#: prefs.xml:195
msgid ""
"Auto-expand updates list if updates count is less than this number (0 to "
"disable)"
msgstr ""
"הרחבה אוטומטית של רשימת עדכונים אם מספר העדכונים נמוכה ממספר זה (0 כדי "
"להשבית)"

#: prefs.xml:209 prefs.xml:269
msgid "Strip out versions numbers"
msgstr "הסר את מספרי הגרסאות"

#: prefs.xml:221
msgid "Show date/time of last check"
msgstr "הצג תאריך/זמן של הבדיקה האחרונה"

#: prefs.xml:236
msgid "Notification"
msgstr "התראה"

#: prefs.xml:239
msgid "Send a notification when new updates are available"
msgstr "שלח התראה כאשר יש עדכונים חדשים זמינים"

#: prefs.xml:252
msgid "How much information to show on notifications"
msgstr "כמה מידע להציג בהתראות"

#: prefs.xml:259
msgid "Count only"
msgstr "רק כמות העדכונים"

#: prefs.xml:260
msgid "New updates names"
msgstr "שמות העדכונים החדשים"

#: prefs.xml:261
msgid "All updates names"
msgstr "כל שמות העדכונים"

#: prefs.xml:283
msgid "Advanced settings"
msgstr "הגדרות מתקדמות"

#: prefs.xml:288
msgid "Command to check for package updates"
msgstr "פקודה לבדיקת עדכוני חבילות"

#: prefs.xml:311
msgid ""
"Disable output parsing, count every line as an update. This is the old "
"behavior."
msgstr "השבת ניתוח פלט, ספור כל שורה כעדכון. זוהי ההתנהגות הישנה."

#: prefs.xml:327
msgid "Command to update packages"
msgstr "פקודה לעדכון חבילות"

#: prefs.xml:342
msgid ""
"Package manager local directory path - To detect when new packages are "
"installed"
msgstr "נתיב ספרייה מקומית של מנהל החבילות - לזיהוי כאשר חבילות חדשות מותקנות"

#: prefs.xml:359
msgid "Command to open package manager (optional)"
msgstr "פקודה לפתוח את מנהל החבילות (אופציונלי)"

#: prefs.xml:374
msgid "Command to show info for a package (optional)"
msgstr "פקודה להצגת מידע על חבילה (אופציונלי)"

#: prefs.xml:389
msgid "About"
msgstr "אודות"

