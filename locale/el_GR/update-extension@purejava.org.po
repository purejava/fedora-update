#: extension.js:437 extension.js:443
msgid "New Fedora Linux Update"
msgid_plural "New Fedora Linux Updates"
msgstr[0] "Νέα ενημέρωση του Fedora Linux"
msgstr[1] "Νέες ενημερώσεις του Fedora Linux"

#: extension.js:444
#, javascript-format
msgid "There is %d update pending"
msgid_plural "There are %d updates pending"
msgstr[0] "Υπάρχει %d ενημέρωση σε εκκρεμότητα"
msgstr[1] "Υπάρχουν %d ενημερώσεις σε εκκρεμότητα"

#: extension.js:460 extension.js:485
msgid "Note : you have to install dnf to use the 'check for updates' script."
msgstr ""
"Σημείωση: πρέπει να εγκαταστήσετε το dnf για χρήση της δέσμης ενεργειών "
"ελέγχου για ενημερώσεις."

#: extension.js:462 extension.js:487
msgid "Error"
msgstr "Σφάλμα"

#: extension.js:467 extension.js:492
msgid "Up to date :)"
msgstr "Ενημερωμένο σύστημα :)"

#: prefs.xml:44
msgid "Basic settings"
msgstr "Βασικές ρυθμίσεις"

#: prefs.xml:49
msgid "Checking for updates"
msgstr "Έλεγχος για ενημερώσεις"

#: prefs.xml:52
msgid "Time to wait before first check (seconds)"
msgstr "Χρόνος αναμονής πριν από τον πρώτο έλεγχο (δευτερόλεπτα)"

#: prefs.xml:64
msgid "Interval between updates check (minutes)"
msgstr "Χρονικό διάστημα μεταξύ ελέγχων για ενημερώσεις (λεπτά)"

#: prefs.xml:79
msgid "Indicator"
msgstr "Ένδειξη"

#: prefs.xml:82
msgid "Always visible"
msgstr "Πάντα ορατή"

#: prefs.xml:94
#, fuzzy
msgid "Disable indicator, until at least N updates are available"
msgstr "Αποστολή ειδοποίησης όταν διατίθενται νέες ενημερώσεις"

#: prefs.xml:119
msgid ""
"Warning: Delaying notifications until multiple updates are available can "
"hide important security updates and is dangerous."
msgstr ""

#: prefs.xml:129
msgid "Use built-in icons"
msgstr "Χρήση ενσωματωμένων εικονιδίων"

#: prefs.xml:141
msgid "Show updates count on indicator"
msgstr "Εμφάνιση αριθμού ενημερώσεων στην ένδειξη"

#: prefs.xml:153
msgid "Position in Panel"
msgstr "Θέση στη γραμμή"

#: prefs.xml:171
msgid "Left"
msgstr "Αριστερά"

#: prefs.xml:172
msgid "Center"
msgstr "Κέντρο"

#: prefs.xml:173
msgid "Right"
msgstr "Δεξιά"

#: prefs.xml:192
msgid "Menu"
msgstr "Μενού"

#: prefs.xml:195
msgid ""
"Auto-expand updates list if updates count is less than this number (0 to "
"disable)"
msgstr ""
"Αυτόματη ανάπτυξη λίστας ενημερώσεων εάν είναι λιγότερες από αυτόν τον "
"αριθμό (0 για απενεργοποίηση)"

#: prefs.xml:209 prefs.xml:269
msgid "Strip out versions numbers"
msgstr "Απόκρυψη αριθμών εκδόσεων"

#: prefs.xml:221
msgid "Show date/time of last check"
msgstr "Εμφάνιση ημερομηνίας/ώρας τελευταίου ελέγχου"

#: prefs.xml:236
msgid "Notification"
msgstr "Ειδοποίηση"

#: prefs.xml:239
msgid "Send a notification when new updates are available"
msgstr "Αποστολή ειδοποίησης όταν διατίθενται νέες ενημερώσεις"

#: prefs.xml:252
msgid "How much information to show on notifications"
msgstr "Ποσότητα πληροφοριών για τις ειδοποιήσεις"

#: prefs.xml:259
msgid "Count only"
msgstr "Μόνο αριθμός"

#: prefs.xml:260
msgid "New updates names"
msgstr "Ονόματα νέων ενημερώσεων"

#: prefs.xml:261
msgid "All updates names"
msgstr "Ονόματα όλων των ενημερώσεων"

#: prefs.xml:283
msgid "Advanced settings"
msgstr "Σύνθετες ρυθμίσεις"

#: prefs.xml:288
msgid "Command to check for package updates"
msgstr "Εντολή ελέγχου για ενημερώσεις πακέτων"

#: prefs.xml:311
msgid ""
"Disable output parsing, count every line as an update. This is the old "
"behavior."
msgstr ""
"Απενεργοποίηση ανάλυσης εξόδου, λογισμός κάθε γραμμής ως ενημέρωσης (παλιά "
"συμπεριφορά)."

#: prefs.xml:327
msgid "Command to update packages"
msgstr "Εντολή ενημέρωσης πακέτων"

#: prefs.xml:342
msgid ""
"Package manager local directory path - To detect when new packages are "
"installed"
msgstr ""
"Διαδρομή τοπικού καταλόγου διαχείρισης πακέτων (για εντοπισμό νέων "
"εγκαταστάσεων πακέτων)"

#: prefs.xml:359
msgid "Command to open package manager (optional)"
msgstr "Εντολή ανοίγματος διαχείρισης πακέτων (προαιρετικό)"

#: prefs.xml:374
msgid "Command to show info for a package (optional)"
msgstr "Εντολή εμφάνισης πληροφοριών πακέτου (προαιρετικό)"

#: prefs.xml:389
msgid "About"
msgstr "Πληροφορίες"

