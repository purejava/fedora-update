#: prefs.xml:195
msgid ""
"Auto-expand updates list if updates count is less than this number (0 to "
"disable)"
msgstr ""
"Автоматично розширювати список оновлень, якщо кількість оновлень менше цього "
"числа (0, щоб вимкнути)"

#: prefs.xml:209 prefs.xml:269
msgid "Strip out versions numbers"
msgstr "Видалити номери версій"

#: prefs.xml:221
msgid "Show date/time of last check"
msgstr "Показати дату/час останньої перевірки"

#: prefs.xml:236
msgid "Notification"
msgstr "Сповіщення"

#: prefs.xml:239
